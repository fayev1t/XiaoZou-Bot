LOG_LEVEL=DEBUG
ENVIRONMENT=dev
DRIVER=~fastapi
LOCALSTORE_USE_CWD=true
ONEBOT_ACCESS_TOKEN=your_onebot_access_token
HOST=0.0.0.0
PORT=8080
SUPERUSERS=["123456789"]
NICKNAME=["小奏"]
COMMAND_START=["/", ""]
COMMAND_SEP=["."]
QQBOT_ENABLE_TEST_EVENTS=0

DATABASE_URL=sqlite+aiosqlite:///./sqlite_data/qqbot.db

LLM_PROVIDER=openai
LLM_API_KEY=your_llm_api_key
LLM_MODEL=gpt-5.4
LLM_TEMPERATURE=0.7
LLM_BASE_URL=https://xxxx/v1
LLM_MAX_TOKENS=500
