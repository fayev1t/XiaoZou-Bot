# 应用运行配置
LOG_LEVEL=DEBUG
ENVIRONMENT=dev
DRIVER=~fastapi
LOCALSTORE_USE_CWD=true
ONEBOT_ACCESS_TOKEN=your_onebot_access_token
HOST=0.0.0.0
PORT=7500
SUPERUSERS=["123456789"]
NICKNAME=["小奏"]
COMMAND_START=["/", ""]
COMMAND_SEP=["."]
QQBOT_ENABLE_TEST_EVENTS=0

# 应用数据库：双机部署时，应用服务器直接访问 Docker 服务服务器上的 PostgreSQL
DATABASE_URL=postgresql+asyncpg://admin:your_postgres_password@your_docker_service_host:7504/mydb

# LLM 配置（单服务商形态；config/model_providers.json 存在时下面四个服务商字段被忽略，
# LLM_TEMPERATURE / LLM_MAX_TOKENS 仍作全局缺省）
LLM_PROVIDER=openai
LLM_API_KEY=your_llm_api_key
LLM_MODEL=gpt-5.4
LLM_TEMPERATURE=0.7
LLM_BASE_URL=https://xxxx/v1
LLM_MAX_TOKENS=500

# ── 多服务商 LLM 路由（可选；契约见 开发文档/v2.0/20-横切契约/LLM路由契约.md）──
# 注册表在 JSON 配置文件 config/model_providers.json（模板：config/model_providers.example.json；真实
# 文件含各服务商 api_key，已被 .gitignore 排除，勿提交）。文件三段：
#   providers  服务商注册表（name / base_url / api_key / 持有的 models）
#   roles      用途 → 模型名（planner / replyer / caption / default；可钉死服务商）
#   settings   全局策略与冷却（缺省 strategy=random：调用只给模型名，在持有该
#              模型的服务商里随机选；planner 这类长前缀高频场景在意前缀缓存命中
#              率的话，可按 role 覆写为 primary_failover）
# 配置文件路径可用下面的 env 覆写（默认 <项目根>/config/model_providers.json）：
# MODEL_PROVIDERS_PATH=./config/model_providers.json

# NapCat 重要配置（当前 docker/napcat/compose.yml 对照值）
NAPCAT_WEBUI_HOST_PORT=7501
NAPCAT_HTTP_HOST_PORT=7502
NAPCAT_WS_HOST_PORT=7503

# Postgres 重要配置（当前 docker/postgres/compose.yml 对照值）
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=mydb
POSTGRES_HOST_PORT=7504

# websearch 工具搜索后端：exa（默认，免 key，Exa 托管 MCP）或 tavily
WEBSEARCH_PROVIDER=exa
# 仅 WEBSEARCH_PROVIDER=tavily 时需要：https://app.tavily.com 注册获取
TAVILY_API_KEY=tvly-your-tavily-api-key

# Prompt 快照（可观测性基线，待办 #11）：每次 LLM 请求落一份完整快照
# （system prompt 分段统计 / user XML / 响应 / token 用量 / 耗时），
# 供排障与 prompt 改动回放对比。代码默认关闭；部署侧建议开启。
PROMPT_SNAPSHOT_ENABLED=true
PROMPT_SNAPSHOT_DIR=./runtime_data/prompt_snapshots
# 目录内快照文件总数上限，超限删最旧
PROMPT_SNAPSHOT_KEEP=200
# 允许落盘的 scope 前缀白名单（私聊默认不落盘）
PROMPT_SNAPSHOT_SCOPES=group,system
